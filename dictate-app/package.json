{
	"name": "dictate-app",
	"version": "1.0.0",
	"description": "Dictate desktop MVP (ElectroBun + React + Python sidecar)",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
		"lint": "biome check src sidecar/worker.py sidecar/bootstrap.ps1 sidecar/requirements.txt README.md package.json components.json electrobun.config.ts postcss.config.js tailwind.config.js tsconfig.json tsconfig.typecheck.json vite.config.ts"
	},
	"dependencies": {
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.14.4",
		"lucide-react": "^0.576.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/bun": "1.3.8",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.2.1",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
